# CMake build directory
build/

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Test Results
*.out.xml
cpputest_*.xml

# vscode logs
*.log

# Local devcontainer Dockerfile (not committed - see .devcontainer/Dockerfile header)
.devcontainer/Dockerfile

# compile_commands.json copied to workspace root by CMake Tools extension
compile_commands.json

# BDD output (written at runtime)
Bdd/output/*
!Bdd/output/.gitkeep
Bdd/junit/*
!Bdd/junit/.gitkeep

# Claude Code local config
.claude/
